# ── MongoDB ─────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=admin_dongguk
MONGO_INITDB_ROOT_PASSWORD=changeme_strong_password
MONGO_INITDB_DATABASE=lab_reservation
MONGO_PORT=27017

# ── MongoDB 연결 URI (백엔드에서 직접 사용) ───────────
# 동일 서버: mongodb://admin_dongguk:<password>@lab-mongodb:27017/lab_reservation?authSource=admin
# 외부 접근: mongodb://admin_dongguk:<password>@<EC2_PUBLIC_IP>:27017/lab_reservation?authSource=admin
MONGO_URI=mongodb://admin_dongguk:changeme_strong_password@43.203.187.64:27017/lab_reservation?authSource=admin

# ── JWT ─────────────────────────────────────────────
ACCESS_TOKEN_SECRET=your_access_token_secret_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# ── CORS ────────────────────────────────────────────
CORS_ORIGIN=https://ethany.org

# ── AWS EC2 호스트 IP (Docker 제어 시 사용) ──────────
HOST_IP=<EC2_PUBLIC_IP>

# ── 도메인 / SSL (certbot) ────────────────────────────
DOMAIN=ethany.org
CERTBOT_EMAIL=admin@ethany.org

# ── Frontend 빌드 타임 설정 ───────────────────────────
VITE_GRAFANA_URL=https://ethany.org/grafana

# ── Grafana ─────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme_grafana_password
GF_SERVER_ROOT_URL=https://ethany.org/grafana/

# ── 이메일 (Nodemailer / Gmail) ──────────────────────
# Gmail 앱 비밀번호: https://myaccount.google.com/apppasswords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# ── Web Push (VAPID) ─────────────────────────────────
# 생성 방법: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:admin@ethany.org
